# Google Gemini API Key (Required)
API_KEY=AIzaSy...

# Resend API Key for Transactional Emails (Required for waitlist)
RESEND_API_KEY=re_...

# Stripe Payment Links (Optional - for Real Payments)
STRIPE_PAYMENT_LINK_SINGLE=https://buy.stripe.com/test_...
STRIPE_PAYMENT_LINK_LIFETIME=https://buy.stripe.com/test_...

# Stripe Keys (Optional - for Webhooks/Verification)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase / PostgreSQL Connection
# Connect to Supabase via connection pooling with Supavisor.
DATABASE_URL="postgres://postgres.xxxx:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations.
DIRECT_URL="postgres://postgres.xxxx:[password]@aws-0-us-west-1.pooler.supabase.com:5432/postgres"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
